{
  "name": "@mnmx/core",
  "version": "0.1.0",
  "description": "Minimax-optimal cross-chain routing engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "backtest": "tsx scripts/backtest.ts",
    "status": "tsx scripts/live-status.ts",
    "transfer": "tsx scripts/live-transfer.ts"
  },
  "author": "MNMX Protocol",
  "license": "MIT",
  "keywords": [
    "solana",
    "minimax",
    "mev",
    "defi",
    "game-theory",
    "on-chain",
    "ai-agent"
  ],
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
