# Solana cluster to interact with. Values: mainnet-beta, devnet, localhost.
UNBRIDGE_NETWORK=mainnet-beta

# RPC endpoint. Use a paid provider for production; the public one is rate-limited.
UNBRIDGE_RPC_URL=https://api.mainnet-beta.solana.com

# Path to the wallet keypair used for signing transactions.
# Never commit this file. Never share its contents.
UNBRIDGE_KEYPAIR_PATH=~/.config/solana/id.json

# Program ID of the shielded-pool program on the target cluster.
# The mainnet value is fixed; override only for devnet or localnet.
UNBRIDGE_PROGRAM_ID=6ESjwd4u6qW8SP9PtNwNus1hBJTxKViWra91C36RRALu

# Relayer endpoint that pays gas for shielded withdrawals.
# Empty means self-submit (the vault owner pays gas and links the recipient).
UNBRIDGE_RELAYER_URL=https://relay.unbridge.dev

# Log level for the client bundle. Values: error, warn, info, debug, trace.
UNBRIDGE_LOG_LEVEL=info
