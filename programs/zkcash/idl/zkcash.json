  "metadata": {
    "name": "zkcash",
    "version": "0.6.0",
    "spec": "0.1.0",
    "description": "Unbridge shielded-pool program: private team multisig on Solana. FROST-authorized spends verified inside Groth16."
  },
  "instructions": [
    {
      "name": "initialize",
      "docs": ["One-time pool init. Admin-gated. Creates the Merkle tree, treasury PDA, and global config."],
      "discriminator": [175, 175, 109, 31, 13, 152, 155, 237],
      "accounts": [
        {"name": "authority", "signer": true, "writable": true},
        {"name": "tree_account", "writable": true},
        {"name": "tree_token_account", "writable": true},
        {"name": "global_config", "writable": true},
        {"name": "system_program"}
      ],
      "args": []
    },
    {
      "name": "update_deposit_limit",
      "docs": ["Admin adjusts the per-transaction deposit cap. Does not move funds."],
      "discriminator": [232, 24, 220, 209, 76, 249, 84, 200],
      "accounts": [
        {"name": "authority", "signer": true},
        {"name": "tree_account", "writable": true}
      ],
      "args": [{"name": "new_limit", "type": "u64"}]
    },
    {
      "name": "update_global_config",
      "docs": ["Admin adjusts fee rates, error margins, and other pool parameters. Does not move funds."],
      "discriminator": [164, 84, 130, 189, 111, 58, 250, 200],
      "accounts": [
        {"name": "authority", "signer": true},
        {"name": "global_config", "writable": true}
      ],
      "args": [
        {"name": "deposit_fee_rate", "type": {"option": "u16"}},
        {"name": "withdrawal_fee_rate", "type": {"option": "u16"}},
        {"name": "fee_error_margin", "type": {"option": "u16"}}
      ]
    },
    {
      "name": "push_association_root",
      "docs": ["ASP authority publishes a new association-set root for compliance filtering. Does not move funds."],
      "discriminator": [216, 61, 137, 232, 44, 129, 191, 116],
      "accounts": [
        {"name": "asp_authority", "signer": true},
        {"name": "global_config", "writable": true}
      ],
      "args": [{"name": "root", "type": {"array": ["u8", 32]}}]
    },
    {
      "name": "set_asp_authority",
      "docs": ["Admin hands off the ASP role to a separate authority. Does not move funds."],
      "discriminator": [173, 246, 129, 5, 121, 191, 60, 130],
      "accounts": [
        {"name": "authority", "signer": true},
        {"name": "global_config", "writable": true}
