        {"name": "encrypted_output2", "type": "bytes"}
      ]
    },
    {
      "name": "transact",
      "docs": ["Shielded spend with 2 inputs and 2 outputs. Full spend proof. Nullifier accounts are created to prevent double-spend. Relayer paid from the pool's prepaid fee buffer."],
