      "args": [{"name": "new_asp_authority", "type": "pubkey"}]
    },
    {
      "name": "initialize_tree_account_for_spl_token",
      "docs": ["Admin creates a Merkle tree for a specific SPL mint. Mint must be in the ALLOWED_TOKENS list (empty on mainnet)."],
      "discriminator": [138, 42, 51, 217, 214, 33, 90, 195],
      "accounts": [
        {"name": "authority", "signer": true, "writable": true},
        {"name": "mint"},
        {"name": "tree_account", "writable": true},
        {"name": "tree_token_account", "writable": true},
        {"name": "token_program"},
        {"name": "associated_token_program"},
        {"name": "system_program"}
      ],
      "args": []
    },
    {
      "name": "update_deposit_limit_for_spl_token",
      "docs": ["Admin adjusts the per-tx deposit cap for a specific SPL mint's tree."],
      "discriminator": [80, 168, 105, 219, 44, 141, 89, 78],
      "accounts": [
        {"name": "authority", "signer": true},
        {"name": "tree_account", "writable": true}
      ],
      "args": [{"name": "new_limit", "type": "u64"}]
    },
    {
      "name": "deposit",
      "docs": ["Add a note to the shielded pool. 4-input Groth16 proof. Deposit must be exactly one of the ten standard denominations."],
      "discriminator": [242, 35, 198, 137, 82, 225, 242, 182],
      "accounts": [
        {"name": "signer", "signer": true, "writable": true},
        {"name": "tree_account", "writable": true},
        {"name": "tree_token_account", "writable": true},
        {"name": "global_config"},
